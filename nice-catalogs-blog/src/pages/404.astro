---
import Base from "../layouts/Base.astro";
---

<Base title="Page not found">
	<div class="not-found">
		<h1>404</h1>
		<p>The page you're looking for doesn't exist.</p>
		<a href="/" class="cta-button cta-button--large">Go back home</a>
	</div>
</Base>

<style>
	.not-found {
		text-align: center;
		padding: 6rem 1.5rem;
	}

	.not-found h1 {
		font-size: 5rem;
		font-weight: 800;
		margin-bottom: 0.5rem;
		color: var(--color-border);
	}

	.not-found p {
		color: var(--color-muted);
		font-size: 1.125rem;
		margin-bottom: 2rem;
	}
</style>
