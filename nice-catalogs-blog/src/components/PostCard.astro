---
import type { MediaValue, ContentBylineCredit } from "emdash";
import { Image } from "emdash/ui";

interface Props {
	title: string;
	excerpt?: string;
	featuredImage?: MediaValue | string;
	href: string;
	date?: Date;
	readingTime?: number;
	tags?: Array<{ slug: string; label: string }>;
	bylines?: ContentBylineCredit[];
}

const {
	title,
	excerpt,
	featuredImage,
	href,
	date,
	readingTime,
	tags,
	bylines,
} = Astro.props;

const formattedDate = date
	? date.toLocaleDateString("en-US", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	: null;
---

<article class="post-card">
	{
		featuredImage && (
			<a href={href} class="card-image-link">
				<Image image={featuredImage} />
			</a>
		)
	}
	<div class="card-body">
		<div class="card-meta">
			{
				tags && tags.length > 0 && (
					<a href={`/tag/${tags[0].slug}`} class="card-category-pill">
						{tags[0].label}
					</a>
				)
			}
			{formattedDate && <span class="card-date">{formattedDate}</span>}
		</div>
		<a href={href} class="card-title-link">
			<h3 class="card-title">{title}</h3>
		</a>
		{
			excerpt && (
				<p class="card-excerpt">{excerpt}</p>
			)
		}
		<a href={href} class="card-read-more">
			Read more &rarr;
		</a>
	</div>
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		background: white;
		border-radius: var(--radius-lg);
		overflow: hidden;
		border: 1px solid var(--color-border-subtle);
		box-shadow: var(--shadow-sm);
		transition: all 300ms ease;
	}

	.post-card:hover {
		box-shadow: var(--shadow-xl);
		border-color: var(--color-border);
		transform: translateY(-2px);
	}

	.card-image-link {
		display: block;
		overflow: hidden;
	}

	.card-image-link img {
		width: 100%;
		height: 12rem;
		object-fit: cover;
		transition: transform 300ms ease;
	}

	.post-card:hover .card-image-link img {
		transform: scale(1.03);
	}

	.card-body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.card-category-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.25rem 0.75rem;
		border-radius: var(--radius-full);
		background: var(--color-accent-bg);
		color: var(--color-accent) !important;
		font-size: 0.875rem;
		font-weight: 500;
		text-decoration: none;
		transition: all var(--transition-fast);
	}

	.card-category-pill:hover {
		background: var(--color-accent);
		color: white !important;
	}

	.card-date {
		font-size: 0.75rem;
		color: var(--color-muted-light);
	}

	.card-title-link {
		text-decoration: none;
		color: inherit;
	}

	.card-title {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--color-text);
		line-height: 1.3;
		transition: color var(--transition-fast);
	}

	.card-title-link:hover .card-title {
		color: var(--color-accent);
	}

	.card-excerpt {
		margin-top: 0.5rem;
		font-size: 0.875rem;
		color: var(--color-text-secondary);
		line-height: 1.6;
		flex: 1;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-read-more {
		margin-top: 1rem;
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--color-accent) !important;
		text-decoration: none;
		transition: all var(--transition-fast);
	}

	.card-read-more:hover {
		text-decoration: underline;
	}
</style>
